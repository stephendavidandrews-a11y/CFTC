# CFTC Regulatory Operations Platform — Production Environment
# Copy this to .env and fill in real values

# Domain
DOMAIN=cftc.yourdomain.com

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-XXXXX

# App secret (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Pipeline Backend Auth
PIPELINE_USER=admin
PIPELINE_PASS=CHANGE_ME

# Tracker Auth
TRACKER_USER=admin
TRACKER_PASS=CHANGE_ME

# Email (SMTP) — for automated status emails and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
MANAGER_EMAIL=stephen@example.com
