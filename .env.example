# CFTC Regulatory Operations Platform — Environment Variables
# Copy this to .env and fill in real values

# ── Domain ──
DOMAIN=cftc.yourdomain.com

# ── Anthropic API Key (required for AI extraction) ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── App Environment ──
# Set to "production" to enforce auth requirements and fail-closed behavior
APP_ENV=development

# ── Tracker Service (port 8004) ──
TRACKER_USER=admin
TRACKER_PASS=change-me-generate-with-openssl
# TRACKER_DB_PATH=/path/to/tracker.db  # defaults to services/tracker/data/tracker.db
# TRACKER_UPLOAD_DIR=/path/to/uploads   # defaults to services/tracker/uploads
# TRACKER_PORT=8004
# TRACKER_HOST=127.0.0.1

# ── AI Service (port 8006) ──
AI_AUTH_USER=admin
AI_AUTH_PASS=change-me-generate-with-openssl
# AI_DB_PATH=/path/to/ai.db            # defaults to services/ai/data/ai.db
# AI_UPLOAD_DIR=/path/to/uploads        # defaults to services/ai/uploads
# AI_AUDIO_WATCH_DIR=/path/to/inbox     # defaults to services/ai/audio-inbox
# AI_PORT=8006
# AI_HOST=127.0.0.1
# AI_CONFIG_PATH=/path/to/ai_policy.json
# LOCAL_TIMEZONE=America/New_York

# ── Email / SMTP (for automated briefs and alerts) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
MANAGER_EMAIL=manager@example.com

# ── Optional: OpenAI (if using GPT models) ──
# OPENAI_API_KEY=your-openai-key-here
